{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Play Defender (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "vite: dev",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "/src/*":          "${workspaceFolder}/src/*",
                "webpack:///./*":  "${workspaceFolder}/*"
            }
        }
    ]
}
